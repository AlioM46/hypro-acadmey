{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/send",
      "destination": "/api/send"
    },
    {
      "source": "/((?!api/|assets/|images/|trainers/|.*\\..*$).*)",
      "destination": "/index.html"
    }
  ]
}

