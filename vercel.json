{
  "version": 2,
  "builds": [
    {
      "src": "api/send.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    {
      "src": "/api/send",
      "dest": "api/send.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}